{
  "name": "carnet-rose",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "web": "expo start --web",
    "web:clear": "expo start --web --clear",
    "web:export": "expo export --platform web",
    "pwa:build": "expo export --platform web",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "test": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "android:prebuild": "expo prebuild --platform android",
    "android:apk:debug": "cd android && gradlew.bat assembleDebug",
    "build:android:apk": "eas build --platform android --profile preview",
    "build:android:production": "eas build --platform android --profile production"
  },
  "dependencies": {
    "@expo-google-fonts/nunito": "^0.2.3",
    "@expo-google-fonts/nunito-sans": "^0.2.3",
    "@expo-google-fonts/patrick-hand": "^0.4.1",
    "@expo/vector-icons": "^15.0.2",
    "@react-navigation/bottom-tabs": "^7.16.1",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.15.1",
    "expo": "~55.0.24",
    "expo-clipboard": "~55.0.13",
    "expo-font": "~55.0.7",
    "expo-haptics": "~55.0.14",
    "expo-linear-gradient": "~55.0.14",
    "expo-sqlite": "~55.0.16",
    "localforage": "^1.10.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gifted-charts": "^1.4.47",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "^19.2.14",
    "@types/react-test-renderer": "^19.1.0",
    "babel-jest": "^29.7.0",
    "babel-preset-expo": "^55.0.21",
    "eas-cli": "^18.12.3",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.17",
    "prettier": "^3.8.3",
    "react-test-renderer": "^19.2.0",
    "typescript": "^6.0.3"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "<rootDir>/carnet-rose/"
    ],
    "collectCoverageFrom": [
      "controllers/**/*.{ts,tsx}",
      "models/**/*.{ts,tsx}",
      "database/**/*.{ts,tsx}",
      "components/**/*.{ts,tsx}",
      "!**/node_modules/**"
    ]
  }
}
